# Copy to .env for local connector development.
# Do not commit real tokens.

# LinkedIn Ads
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=
# Optional; defaults to the current Marketing API version used by the connector.
LINKEDIN_VERSION=

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Ads / YouTube
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Optional; defaults to the current Google Ads API version used by the connector.
GOOGLE_ADS_API_VERSION=

# Display & Video 360
GOOGLE_APPLICATION_CREDENTIALS=
DV360_ADVERTISER_ID=
DV360_PARTNER_ID=

# Microsoft Advertising
MICROSOFT_ADS_DEVELOPER_TOKEN=
MICROSOFT_ADS_CUSTOMER_ID=
MICROSOFT_ADS_ACCOUNT_ID=
MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_REFRESH_TOKEN=
# Optional; defaults to Microsoft Advertising OAuth scope.
MICROSOFT_ADS_SCOPE=

# Reddit Ads
REDDIT_ADS_ACCESS_TOKEN=
REDDIT_AD_ACCOUNT_ID=

# X Ads
X_ADS_ACCESS_TOKEN=
X_AD_ACCOUNT_ID=

# TikTok Ads
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
